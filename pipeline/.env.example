# Docker Compose 환경에서는 DATABASE_URL이 자동 주입됨
# 로컬 직접 실행 시에만 아래 값 사용
DATABASE_URL=postgresql://feefluencer:feefluencer@localhost:5432/feefluencer
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx

# 배치 설정
DISCOVERY_CRON=0 9 * * 1        # 매주 월요일 오전 9시
ENRICHMENT_CRON=0 10 * * 3      # 매주 수요일 오전 10시
REFRESH_CRON=0 8 * * *           # 매일 오전 8시 (hot tier)

# Apify actor IDs
HASHTAG_SCRAPER_ACTOR=apify/instagram-hashtag-scraper
PROFILE_SCRAPER_ACTOR=apify/instagram-profile-scraper
POST_SCRAPER_ACTOR=apify/instagram-post-scraper

# 수집 설정
HASHTAG_RESULTS_LIMIT=300        # 해시태그당 게시물 수집 수
POST_RESULTS_LIMIT=30            # 계정당 게시물 수집 수
PROFILE_BATCH_SIZE=50            # 프로필 배치 크기
DISCOVERY_HASHTAG_BATCH=5        # 1회 배치에서 처리할 해시태그 수
ENRICHMENT_BATCH_SIZE=20         # 1회 enrichment 배치 크기

# API 서버
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173
